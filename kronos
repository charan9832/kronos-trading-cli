class BacktestEngine:
    """Run backtests on strategies."""
    
    def __init__(self):
        self.results = {}
    
    def run(self, strategy_name: str, symbol: str = "SPY", 
            start_date: str = "2020-01-01", end_date: str = "2024-12-31",
            initial_capital: float = 100000.0) -> Dict[str, Any]:
        """Run a backtest."""
        import numpy as np
        import pandas as pd
        
        # Load strategy
        strategy_file = STRATEGIES_DIR / f"{strategy_name}.py"
        if not strategy_file.exists():
            raise ValueError(f"Strategy '{strategy_name}' not found")
        
        # Import strategy module
        import importlib.util
        spec = importlib.util.spec_from_file_location(strategy_name, strategy_file)
        module = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(module)
        
        # Generate mock price data (in production, use real data)
        dates = pd.date_range(start_date, end_date, freq='B')
        np.random.seed(42)
        returns = np.random.randn(len(dates)) * 0.01
        prices = pd.Series(100 * np.exp(np.cumsum(returns)), index=dates)
        
        # Generate signals
        signals = module.generate_signals(prices)
        
        # Calculate returns
        strategy_returns = signals.shift(1) * prices.pct_change()
        strategy_returns = strategy_returns.dropna()
        
        # Calculate metrics
        equity_curve = initial_capital * (1 + strategy_returns).cumprod()
        
        total_return = (equity_curve.iloc[-1] / initial_capital - 1) * 100
        sharpe = strategy_returns.mean() / strategy_returns.std() * np.sqrt(252)
        max_dd = ((equity_curve.cummax() - equity_curve) / equity_curve.cummax()).max() * 100
        win_rate = (strategy_returns > 0).sum() / (strategy_returns != 0).sum() * 100
        
        results = {
            "strategy": strategy_name,
            "symbol": symbol,
            "period": f"{start_date} to {end_date}",
            "initial_capital": initial_capital,
            "final_equity": equity_curve.iloc[-1],
            "total_return_pct": total_return,
            "sharpe_ratio": sharpe,
            "max_drawdown_pct": max_dd,
            "win_rate_pct": win_rate,
            "num_trades": (signals.diff() != 0).sum(),
            "equity_curve": equity_curve,
            "returns": strategy_returns
        }
        
        self.results[strategy_name] = results
        return results
    
    def print_results(self, results: Dict[str, Any]):
        """Print backtest results in a beautiful format."""
        table = Table(title=f"Backtest Results: {results['strategy']}", box=box.ROUNDED)
        
        table.add_column("Metric", style="cyan")
        table.add_column("Value", style="green")
        
        table.add_row("Period", results['period'])
        table.add_row("Symbol", results['symbol'])
        table.add_row("Initial Capital", f"${results['initial_capital']:,.2f}")
        table.add_row("Final Equity", f"${results['final_equity']:,.2f}")
        table.add_row("Total Return", f"{results['total_return_pct']:+.2f}%")
        table.add_row("Sharpe Ratio", f"{results['sharpe_ratio']:.2f}")
        table.add_row("Max Drawdown", f"{results['max_drawdown_pct']:.2f}%")
        table.add_row("Win Rate", f"{results['win_rate_pct']:.1f}%")
        table.add_row("Num Trades", str(results['num_trades']))
        
        console.print(table)
        
        # Print verdict
        if results['total_return_pct'] > 0 and results['sharpe_ratio'] > 1:
            console.print("\n[bold green]✅ Strategy shows promise[/bold green]")
        elif results['total_return_pct'] < 0:
            console.print("\n[bold red]❌ Strategy has negative returns[/bold red]")
        else:
            console.print("\n[bold yellow]⚠️  Strategy needs improvement[/bold yellow]")


class TradingBot:
    """Autonomous trading bot."""
    
    def __init__(self, config: Config, strategy_name: str):
        self.config = config
        self.strategy_name = strategy_name
        self.running = False
        self.trades = []
    
    async def run(self):
        """Run the trading bot."""
        self.running = True
        
        console.print(f"\n[bold green]🚀 Starting trading bot[/bold green]")
        console.print(f"Mode: [cyan]{self.config.default_mode}[/cyan]")
        console.print(f"Strategy: [cyan]{self.strategy_name}[/cyan]")
        console.print(f"Risk limits: Daily {self.config.risk_daily_loss_pct}%, Max DD {self.config.risk_max_drawdown_pct}%\n")
        
        try:
            while self.running:
                # Simulate trading cycle
                console.print(f"[{datetime.now().strftime('%H:%M:%S')}] Analyzing market...")
                await asyncio.sleep(2)
                
                console.print(f"[{datetime.now().strftime('%H:%M:%S')}] Checking signals...")
                await asyncio.sleep(1)
                
                # Random trade simulation
                import random
                if random.random() > 0.7:
                    action = random.choice(["BUY", "SELL"])
                    size = random.uniform(0.1, 0.5)
                    console.print(f"[bold green]EXECUTED: {action} {size:.2%}[/bold green]")
                    self.trades.append({
                        "time": datetime.now().isoformat(),
                        "action": action,
                        "size": size
                    })
                else:
                    console.print("[dim]No action taken[/dim]")
                
                await asyncio.sleep(3)
                
        except asyncio.CancelledError:
            console.print("\n[bold yellow]Trading bot stopped[/bold yellow]")
    
    def stop(self):
        """Stop the bot."""
        self.running = False



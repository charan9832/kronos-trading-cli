                    continue
                name = args[0]
                template = args[1] if len(args) > 1 else "momentum"
                path = manager.create_strategy(name, template)
                console.print(f"[green]✅ Created: {path}[/green]")
            
            elif command == 'backtest':
                if not args:
                    console.print("[red]Usage: backtest <strategy>[/red]")
                    continue
                strategy = args[0]
                try:
                    results = engine.run(strategy)
                    engine.print_results(results)
                except Exception as e:
                    console.print(f"[red]Error: {e}[/red]")
            
            elif command == 'run':
                strategy = args[0] if args else None
                mode = args[1] if len(args) > 1 else config.default_mode
                
                if not strategy:
                    strategies = manager.list_strategies()
                    if strategies:
                        strategy = strategies[0]['name']
                    else:
                        console.print("[red]No strategies available[/red]")
                        continue
                
                config.default_mode = mode
                bot = TradingBot(config, strategy)
                
                # Run in background
                asyncio.create_task(bot.run())
                console.print(f"[green]🚀 Trading bot started ({mode} mode)[/green]")
            
            elif command == 'stop':
                if bot:
                    bot.stop()
                    bot = None
                    console.print("[yellow]Trading bot stopped[/yellow]")
                else:
                    console.print("[dim]No bot running[/dim]")
            
            elif command == 'status':
                strategies = manager.list_strategies()
                console.print(f"Strategies: {len(strategies)}")
                console.print(f"Mode: {config.default_mode}")
                console.print(f"Bot running: {'Yes' if bot and bot.running else 'No'}")
            
            elif command == 'config':
                for key, value in asdict(config).items():
                    if 'secret' in key:
                        value = "***"
                    console.print(f"  {key}: {value}")
            
            elif command == 'clear':
                console.clear()
                print_banner()
            
            else:
                console.print(f"[red]Unknown command: {command}[/red]")
        
        except KeyboardInterrupt:
            console.print("\n[yellow]Use 'exit' to quit[/yellow]")
        except Exception as e:
            console.print(f"[red]Error: {e}[/red]")


def cmd_repl(args):
    """Start interactive REPL."""
    asyncio.run(repl_session())


def main():
    """Main entry point."""
    parser = argparse.ArgumentParser(
        prog='kronos',
        description='Kronos Trading Agent - Autonomous trading with RL',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  kronos init                          # First-time setup
  kronos strategy create my_strategy   # Create a strategy
  kronos backtest my_strategy          # Run backtest
  kronos run --mode=paper              # Start paper trading
  kronos repl                          # Interactive mode
        """
    )
    
    subparsers = parser.add_subparsers(dest='command', help='Command to run')
    
    # init
    init_parser = subparsers.add_parser('init', help='Initialize Kronos')
    
    # strategy
    strategy_parser = subparsers.add_parser('strategy', help='Manage strategies')
    strategy_subparsers = strategy_parser.add_subparsers(dest='strategy_cmd')
    
    strategy_list_parser = strategy_subparsers.add_parser('list', help='List strategies')
    
    strategy_create_parser = strategy_subparsers.add_parser('create', help='Create strategy')
    strategy_create_parser.add_argument('name', help='Strategy name')
    strategy_create_parser.add_argument('--template', choices=['momentum', 'mean_reversion', 'breakout', 'rl_kronos'],
                                       help='Strategy template')
    
    strategy_edit_parser = strategy_subparsers.add_parser('edit', help='Edit strategy')
    strategy_edit_parser.add_argument('name', help='Strategy name')
    
    # backtest
    backtest_parser = subparsers.add_parser('backtest', help='Run backtest')
    backtest_parser.add_argument('strategy', help='Strategy name')
    backtest_parser.add_argument('--symbol', default='SPY', help='Symbol to trade')
    backtest_parser.add_argument('--start', default='2020-01-01', help='Start date')
    backtest_parser.add_argument('--end', default='2024-12-31', help='End date')
    backtest_parser.add_argument('--capital', type=float, default=100000, help='Initial capital')
    
    # run
    run_parser = subparsers.add_parser('run', help='Start trading')
    run_parser.add_argument('--mode', choices=['paper', 'live'], help='Trading mode')
    run_parser.add_argument('--strategy', help='Strategy to use')
    
    # status
    status_parser = subparsers.add_parser('status', help='Show status')
    
    # config
    config_parser = subparsers.add_parser('config', help='Manage configuration')
    config_parser.add_argument('--set', help='Set config value (key=value)')
    
    # repl
    repl_parser = subparsers.add_parser('repl', help='Interactive REPL mode')
    
    # Parse args
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        sys.exit(1)
    
    # Route to command handler
    try:
        if args.command == 'init':
            cmd_init(args)
        elif args.command == 'strategy':
            if args.strategy_cmd == 'list':
                cmd_strategy_list(args)
            elif args.strategy_cmd == 'create':
                cmd_strategy_create(args)
            elif args.strategy_cmd == 'edit':
                cmd_strategy_edit(args)
            else:
                strategy_parser.print_help()
        elif args.command == 'backtest':
            cmd_backtest(args)
        elif args.command == 'run':
            cmd_run(args)
        elif args.command == 'status':
            cmd_status(args)
        elif args.command == 'config':
            cmd_config(args)
        elif args.command == 'repl':
            cmd_repl(args)
        else:
            parser.print_help()
    except KeyboardInterrupt:
        console.print("\n[dim]Interrupted by user[/dim]")
        sys.exit(130)
    except Exception as e:
        console.print(f"\n[bold red]Error: {e}[/bold red]")
        if os.environ.get('DEBUG'):
            traceback.print_exc()
        sys.exit(1)


if __name__ == '__main__':
    main()

def cmd_backtest(args):
    """Run a backtest."""
    engine = BacktestEngine()
    
    with Progress(
        SpinnerColumn(),
        TextColumn("[progress.description]{task.description}"),
        console=console
    ) as progress:
        task = progress.add_task("[green]Running backtest...", total=None)
        
        try:
            results = engine.run(
                strategy_name=args.strategy,
                symbol=args.symbol,
                start_date=args.start,
                end_date=args.end,
                initial_capital=args.capital
            )
            progress.update(task, completed=True)
        except Exception as e:
            progress.update(task, completed=True)
            console.print(f"[bold red]Backtest failed: {e}[/bold red]")
            traceback.print_exc()
            return
    
    engine.print_results(results)
    
    # Save results
    results_dir = Path("/tmp/kronos_project/results")
    results_dir.mkdir(parents=True, exist_ok=True)
    
    report_file = results_dir / f"backtest_{args.strategy}_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json"
    
    # Remove non-serializable data
    save_results = {k: v for k, v in results.items() if k not in ['equity_curve', 'returns']}
    # Convert equity curve index to strings
    equity_dict = results['equity_curve'].to_dict()
    save_results['equity_curve'] = {str(k): float(v) for k, v in equity_dict.items()}
    save_results['returns'] = {str(k): float(v) for k, v in results['returns'].to_dict().items()}
    
    with open(report_file, 'w') as f:
        json.dump(save_results, f, indent=2, default=str)
    
    console.print(f"\n[dim]Report saved: {report_file}[/dim]")


def cmd_run(args):
    """Start trading."""
    config = Config.load()
    
    if args.mode:
        config.default_mode = args.mode
    
    if args.strategy:
        strategy = args.strategy
    else:
        # Use default or ask
        manager = StrategyManager()
        strategies = manager.list_strategies()
        if not strategies:
            console.print("[red]No strategies found. Create one first:[/red]")
            console.print("  kronos strategy create <name>")
            return
        strategy = strategies[0]['name']
    
    if config.default_mode == "live":
        console.print("[bold red]⚠️  LIVE TRADING MODE[/bold red]")
        if not Confirm.ask("Are you sure you want to trade with real money?"):
            return
    
    # Start trading bot
    bot = TradingBot(config, strategy)
    
    try:
        asyncio.run(bot.run())
    except KeyboardInterrupt:
        bot.stop()
        console.print("\n[bold yellow]Trading stopped by user[/bold yellow]")


